package OBI.algoritmo;

import java.util.Scanner;

public class busca_binaria {
    static void main(String[]args){

        int[] vetor = new int[10];
        Scanner leia = new Scanner(System.in);
        int buscando = leia.nextInt();

        int contador = 0;
        boolean achou = false;
        int inicio= 0;
        int fim = vetor.length;
        int meio;

        for(int i = 0;i< vetor.length;i++){
            vetor[i] = i*2;
        }

        while(inicio<= fim){
            contador++;
            meio =(int) ((inicio+fim)/2);
            if(vetor[meio] == buscando){
                achou = true;
                break;
            }else if(vetor[meio]<buscando){
                inicio = meio+1;
            }else{
                fim = meio -1;
            }
        }

        System.out.println("tester realizados:"+contador);
        if(achou == true){
            System.out.println("achou");
        }else{
            System.out.println("nao achou");
        }
    }
}
